# =========================================================
# TitanCRM Environment Configuration
# =========================================================
# Please fill in all variables below with your own credentials.
# You can obtain all required values by following the setup guide:
# 👉 https://docs.google.com/document/d/1npkPQs9O_Bshj4giDei89BFjfmimeCCjBLWwhh76zYg/edit?usp=sharing
#
# Do NOT use example/demo credentials in production.
# =========================================================


# =========================================================
# General / CRM Configuration
# =========================================================
# Email used for CRM login
# ⚠️ Must be a valid email address, as it will be used for logins and notifications
SEED_ADMIN_EMAIL=youremail@yourdomain.ltd


# =========================================================
# Application Domains
# =========================================================
# Specify your domains for each service
FRONTEND_DOMAIN=yourdomain.ltd
BACKEND_DOMAIN=api.yourdomain.ltd
RABBITMQ_DOMAIN=mq.yourdomain.ltd
PGADMIN_DOMAIN=db.yourdomain.ltd
DOZZLE_DOMAIN=log.yourdomain.ltd


# =========================================================
# Brevo (SMTP / Email Service)
# =========================================================
# Used for sending emails from the application
# IMPORTANT: Make sure to whitelist your server's public IP address
# in Brevo (API Keys / SMTP settings), otherwise requests may be rejected.
BREVO_USER=<brevo_user>
BREVO_API_KEY=<brevo_api>


# =========================================================
# Telegram Bot Configuration
# =========================================================
# Create bot via @BotFather and paste credentials here
TELEGRAM_BOT_NAME=<bot_name>
TELEGRAM_BOT_TOKEN=<bot_token>


# =========================================================
# AWS S3 Storage Configuration
# =========================================================
# Used for storing media files
AWS_S3_HOSTNAME=<bucket_name>.s3.<region>.amazonaws.com
AWS_S3_REGION=<aws_region>
AWS_S3_BUCKET=<bucket_name>
AWS_ACCESS_KEY_ID=<aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<aws_secret_access_key>
